{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/instrument/dist",
  "installCommand": "npm ci",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.vercel.app https://*"
        }
      ]
    }
  ]
}
